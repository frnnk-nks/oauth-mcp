# Copy to .env and fill in. All *_CLIENT_* values come from the provider app configs.

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
# Public https origin used to build OAuth redirect URIs (e.g. an ngrok/cloudflared URL).
# Falls back to http://SERVER_HOST:SERVER_PORT when unset. Outreach requires https;
# Salesforce allows http only for localhost.
SERVER_ORIGIN_PROXY=

# Salesforce connected app (web server flow). Callback URL to register:
#   {SERVER_ORIGIN_PROXY or http://SERVER_HOST:SERVER_PORT}/auth/callback
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Use https://test.salesforce.com for sandbox orgs, or a My Domain URL
SALESFORCE_LOGIN_HOST=https://login.salesforce.com
SALESFORCE_API_VERSION=v56.0
SALESFORCE_LOCAL_TOKEN_PATH=./secrets/salesforce_token.json
# Salesforce doesn't report access-token lifetimes; refresh proactively after this many seconds
SALESFORCE_TOKEN_TTL_SECONDS=1800

# Outreach OAuth app. Redirect URI to register: {SERVER_ORIGIN_PROXY}/auth/callback
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
OUTREACH_OAUTH_BASE_URL=https://api.outreach.io/oauth
OUTREACH_API_BASE_URL=https://api.outreach.io/api/v2
OUTREACH_LOCAL_TOKEN_PATH=./secrets/outreach_token.json
